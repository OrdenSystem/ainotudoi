# ===== AppSheet credentials =====
# 既定アプリ ID（ツール呼び出しで appId を省略した時に使われる）
APPSHEET_DEFAULT_APP_ID=00000000-0000-0000-0000-000000000000

# アプリごとの Application Access Key
# 形式: APPSHEET_ACCESS_KEY__<APP_ID> = <key>
# ハイフンはアンダースコア2つに変換しても OK（解決ロジックで両対応）
APPSHEET_ACCESS_KEY__00000000-0000-0000-0000-000000000000=V2-xxxxx-xxxxx

# 複数アプリを扱う場合は追記する（FIRST_PJ 以外の案件用）
# APPSHEET_ACCESS_KEY__11111111-1111-1111-1111-111111111111=V2-yyyyy-yyyyy

# AppSheet リージョン（既定 www、必要時のみ変更）
APPSHEET_REGION=www

# ===== Playwright ログインアカウント =====
# AppSheet に Playwright でログインする際の Google アカウント (authuser パラメータに渡される)
# cookie:init / refresh_cookie / capture-har で利用される。複数アカウントがある環境でアカウント選択画面をスキップ
# APPSHEET_LOGIN_ACCOUNT=lab@appsheet.fun

# ===== Editor 内部 API 用 Cookie（Phase 4: 書き込み機能） =====
# Editor で DevTools → saveapp 右クリック → Copy as cURL → -b '...' の中身を貼る
# あるいは npm run cookie:init で Playwright が自動取得 (推奨)
# 約 30 日で失効するので定期再取得が必要
# APPSHEET_COOKIE=

# ===== ログレベル =====
LOG_LEVEL=info

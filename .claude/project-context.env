# =============================================================================
# project-context.env — Single Source of Truth for CLI contexts
# =============================================================================
# このファイルは「このリポジトリで CLI を実行する際に期待する context」を
# 一元定義します。`.claude/hooks/*` および CLAUDE.md がここを参照します。
#
# 値はユーザが手で埋めてください（commit 可: 機密値はここに置かない）。
# 機密値（鍵・トークン）は OS のキーチェーンや GCP Secret Manager 等を使用。
# =============================================================================

# --- GCP (gcloud / gsutil / bq) ---
# `gcloud config configurations create ainotudoi` 等で専用 config を作る想定
GCLOUD_CONFIG=ainotudoi
GCLOUD_PROJECT=
GCLOUD_ACCOUNT=
GCLOUD_REGION=asia-northeast1

# --- GitHub (gh) ---
GH_HOST=github.com
GH_USER=

# --- Firebase ---
FIREBASE_PROJECT=

# --- Salesforce (sf / sfdx) ---
SF_ORG_ALIAS=ainotudoi
SF_USERNAME=

# --- AppSheet ---
# AppSheet 側の AppID / Access Key は機密扱い。ここには置かず、
# 個別の .env.local / OS シークレットストアで管理する。
APPSHEET_APP_NAME=

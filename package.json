{
  "name": "appsheet-mcp",
  "version": "0.1.0",
  "description": "MCP server for AppSheet — data CRUD via Application API v2 (Phase 1). Project-agnostic, multi-app capable.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "appsheet-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lab-masuyama/AppsheetMCP.git"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "mcp",
    "appsheet",
    "claude-code",
    "model-context-protocol"
  ],
  "license": "UNLICENSED",

<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>JukyuNumber_Hankaku</fullName>
    <active>true</active>
    <description>受給者証番号は半角数字で入力</description>
    <errorConditionFormula>NOT (  REGEX ( JukyuNumber__c, &quot;^[0-9]*$&quot;))</errorConditionFormula>
    <errorDisplayField>JukyuNumber__c</errorDisplayField>
    <errorMessage>受給者証番号は半角数字で入力してください。</errorMessage>
</ValidationRule>
